{
  "providers": [
    {
      "key": "anthropic",
      "label": "Anthropic 官方",
      "protocol": "anthropic",
      "baseUrl": "https://api.anthropic.com",
      "messagesPath": "/v1/messages",
      "auth": "x-api-key",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "structuredOutput": true,
      "notes": "官方 API；唯一支持结构化输出（output_config.format）的 provider"
    },
    {
      "key": "deepseek",
      "label": "DeepSeek（Anthropic 兼容）",
      "protocol": "anthropic",
      "baseUrl": "https://api.deepseek.com/anthropic",
      "messagesPath": "/v1/messages",
      "auth": "x-api-key",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "structuredOutput": false,
      "notes": "官方 Anthropic 兼容端点；thinking 支持但忽略 budget_tokens（2026-07 官方文档核实）"
    },
    {
      "key": "moonshot",
      "label": "Moonshot Kimi（Anthropic 兼容）",
      "protocol": "anthropic",
      "baseUrl": "https://api.moonshot.cn/anthropic",
      "messagesPath": "/v1/messages",
      "auth": "bearer",
      "apiKeyEnv": "MOONSHOT_API_KEY",
      "structuredOutput": false,
      "notes": "国内端点；海外可改 api.moonshot.ai。官方文档以 ANTHROPIC_AUTH_TOKEN（Bearer）鉴权（2026-07 核实）"
    },
    {
      "key": "zhipu",
      "label": "智谱 GLM（Anthropic 兼容）",
      "protocol": "anthropic",
      "baseUrl": "https://open.bigmodel.cn/api/anthropic",
      "messagesPath": "/v1/messages",
      "auth": "bearer",
      "apiKeyEnv": "ZHIPU_API_KEY",
      "structuredOutput": false,
      "notes": "官方 Claude API 兼容层，Bearer 鉴权（2026-07 官方文档核实）"
    },
    {
      "key": "openai",
      "label": "OpenAI 官方（OpenAI 协议）",
      "protocol": "openai",
      "baseUrl": "https://api.openai.com",
      "messagesPath": "/v1/chat/completions",
      "auth": "bearer",
      "apiKeyEnv": "OPENAI_API_KEY",
      "structuredOutput": false,
      "notes": "chat/completions 端点，Bearer 鉴权（2026-07 官方文档核实）；经网关适配层做 Messages ⇄ chat/completions 转换，流式 tool_use 暂不支持"
    },
    {
      "key": "gemini",
      "label": "Google Gemini（OpenAI 兼容）",
      "protocol": "openai",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
      "messagesPath": "/chat/completions",
      "auth": "bearer",
      "apiKeyEnv": "GEMINI_API_KEY",
      "structuredOutput": false,
      "notes": "官方 OpenAI 兼容端点，Bearer 鉴权（2026-07 官方文档核实）；部分 OpenAI 参数会被其兼容层静默忽略"
    },
    {
      "key": "openrouter",
      "label": "OpenRouter（OpenAI 协议聚合）",
      "protocol": "openai",
      "baseUrl": "https://openrouter.ai/api",
      "messagesPath": "/v1/chat/completions",
      "auth": "bearer",
      "apiKeyEnv": "OPENROUTER_API_KEY",
      "structuredOutput": false,
      "notes": "第三方聚合端点，Bearer 鉴权（2026-07 官方文档核实）；模型 slug 以其 /api/v1/models 为准"
    }
  ],
