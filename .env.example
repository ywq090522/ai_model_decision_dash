# 多模型网关的 provider 密钥（复制为 .env 并填入，.env 已 gitignore）
# 只需填你要用的 provider；未配置的 provider 在调用时返回 401 并提示这里的变量名。
# 任何 key 都不会进入前端构建产物 —— registry.json 只记录这些变量名。

# Anthropic 官方（x-api-key）
ANTHROPIC_API_KEY=

# DeepSeek Anthropic 兼容端点（x-api-key）https://api-docs.deepseek.com/guides/anthropic_api
DEEPSEEK_API_KEY=

# Moonshot Kimi Anthropic 兼容端点（Bearer）https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# 智谱 GLM Anthropic 兼容端点（Bearer）https://docs.bigmodel.cn/cn/guide/develop/claude/introduction
ZHIPU_API_KEY=

# OpenAI 官方 chat/completions（Bearer，经网关协议转换）https://developers.openai.com/api/docs/api-reference/chat
OPENAI_API_KEY=

# Google Gemini OpenAI 兼容端点（Bearer，经网关协议转换）https://ai.google.dev/gemini-api/docs/openai
GEMINI_API_KEY=

# OpenRouter 聚合端点（Bearer，经网关协议转换）https://openrouter.ai/docs/quickstart
OPENROUTER_API_KEY=

# 网关端口（默认 8788）
# GATEWAY_PORT=8788

# 网关监听地址（默认只监听本机回环地址）
GATEWAY_HOST=127.0.0.1

# 网关入站鉴权 token。部署到 VPS 或公网环境时必须设置。
# 设置后，除 /healthz 外所有请求都需要 Authorization: Bearer <token>
GATEWAY_AUTH_TOKEN=

# 数据管线的解析模型（默认 claude-opus-4-8，可换 registry 内任意模型）
# PARSER_MODEL=claude-opus-4-8
